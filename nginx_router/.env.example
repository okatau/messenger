# Домен (без https:// и без trailing slash)
DOMAIN=yourdomain.com

# Email для Let's Encrypt (уведомления об истечении)
CERTBOT_EMAIL=you@example.com

# Registry prefix, например: ghcr.io/your-github-username/messenger
REGISTRY=ghcr.io/your-github-username/messenger

# PostgreSQL
PG_PASSWORD=your_secure_pg_password

# Redis
REDIS_PASSWORD=your_secure_redis_password

PG_HOST=pg_host
PG_PORT=pg_port
PG_USER=pg_user
PG_DBNAME=pg_dbname

AUTH_PUBLIC_PEM_BASE64=replace_me
AUTH_PRIVATE_PEM_BASE64=replace_me

